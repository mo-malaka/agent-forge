# Optional — AgentForge auto-detects from request headers on Amplify
# AGENTFORGE_BASE_URL=https://your-app.amplifyapp.com

# SailPoint ISC (server-side only — never expose to the browser)
ISC_TENANT=your-tenant
ISC_CLIENT_ID=your-client-id
ISC_CLIENT_SECRET=your-client-secret
ISC_SOURCE_ID=your-web-services-source-id
ISC_API_VERSION=v2026
ISC_DOMAIN=identitynow.com

# Optional demo defaults for govern + enforce mode
ISC_DEMO_AGENT_ID=agt_demo_aws_bedrock

# Machine identity schema name(s) for step 4 (comma-separated if multiple)
# ISC_MIS_DATASET_IDS=bedrock-agent

# Optional — display name of the Web Services source (auto-fetched if omitted)
# ISC_SOURCE_NAME=AI Agents Bedrock

# Machine account link attributes (defaults match identity ARN -> AI agent backendId)
# ISC_MIS_LINK_ACCOUNT_ATTR=identity
# ISC_MIS_LINK_TARGET_ATTR=backendId
