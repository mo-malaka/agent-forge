# Optional — AgentForge auto-detects from request headers on Amplify
# AGENTFORGE_BASE_URL=https://main.d12mzah9vzl24s.amplifyapp.com

# SailPoint ISC credentials (server-side only — never expose to the browser)
ISC_TENANT=your-tenant
ISC_CLIENT_ID=your-client-id
ISC_CLIENT_SECRET=your-client-secret

# Optional API defaults
ISC_API_VERSION=v2026
ISC_DOMAIN=identitynow.com

# Web Services source IDs are configured in the AgentForge UI:
# Demo → ISC sources (saved to data/isc-settings.json on the server)

# Optional demo defaults for govern + enforce mode
ISC_DEMO_AGENT_ID=agt_demo_aws_bedrock

# Optional machine identity schema overrides (defaults: bedrock-agent / vertex-agent / foundry-agent)
# ISC_MIS_DATASET_IDS_BEDROCK=bedrock-agent
# ISC_MIS_DATASET_IDS_GCP_VERTEX=vertex-agent
# ISC_MIS_DATASET_IDS_AZURE_FOUNDRY=foundry-agent

# Machine account link attributes (default: nativeIdentity -> nativeIdentity)
# ISC_MIS_LINK_ACCOUNT_ATTR=nativeIdentity
# ISC_MIS_LINK_TARGET_ATTR=nativeIdentity
